# Server
PORT=3000
NODE_ENV=development

# Production: set NODE_ENV=production and a strong JWT_SECRET (min 32 chars).
# JWT secret for auth (required in production; use a long random string)
JWT_SECRET=your-secret-key-change-in-production

# CORS: comma-separated origins allowed (e.g. https://app.example.com). Leave unset in dev to allow any origin.
# CORS_ORIGIN=https://your-frontend.vercel.app,https://app.example.com

# ZeroBounce API key for email validation on signup (optional; if unset, validation is skipped)
# ZEROBOUNCE_API_KEY=

# Neon PostgreSQL (get connection string from https://neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
